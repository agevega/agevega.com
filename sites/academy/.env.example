# ============================================
# Environment Variables for Academy
# ============================================
# Copy this file to .env and fill in the values
#
# IMPORTANT: .env is git-ignored and docker-ignored.
# Never commit secrets to the repository.
# ============================================

# Academy currently has no required env vars at build time.
# This file exists as a template for future use (e.g. Plausible domain
# tracking when academy.agevega.com is live).

# Example (uncomment + adapt when needed):
# PUBLIC_PLAUSIBLE_DOMAIN=academy.agevega.com
# PUBLIC_APP_VERSION=Localhost
