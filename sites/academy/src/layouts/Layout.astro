---
import '@fontsource/varela-round/400.css';
import '../styles/global.css';
import Navigation from '../components/Navigation.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
}

const {
  title,
  description = 'Aprende DevSecOps y Cloud de forma práctica con recursos, código y guías de los vídeos de AgeVega Master.',
  ogImage,
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const fullTitle = `${title} | AgeVega Academy`;
const baseOrigin = Astro.site ? Astro.site.origin : Astro.url.origin;
const ogImageUrl = ogImage ? `${baseOrigin}${ogImage}` : `${baseOrigin}/og-image.jpg`;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/x-icon" href="/favicon.ico?v=2" />
    <meta name="generator" content={Astro.generator} />
    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />

    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImageUrl} />

    <meta property="twitter:card" content="summary_large_image" />
    <meta property="twitter:url" content={canonicalURL} />
    <meta property="twitter:title" content={fullTitle} />
    <meta property="twitter:description" content={description} />
    <meta property="twitter:image" content={ogImageUrl} />

    <link rel="alternate" type="application/rss+xml" title="AgeVega Academy" href="/rss.xml" />
    <slot name="head" />
  </head>
  <body
    class="bg-brand-dark text-slate-100 font-sans antialiased selection:bg-emerald-500/30 overflow-x-hidden relative flex flex-col min-h-screen"
  >
    <a
      href="#main-content"
      class="sr-only focus:not-sr-only focus:fixed focus:top-4 focus:left-4 focus:z-[100] focus:px-4 focus:py-2 focus:bg-emerald-600 focus:text-white focus:rounded-lg focus:outline-none"
    >
      Saltar al contenido
    </a>

    <!-- Background Gradient Effects -->
    <div class="fixed inset-0 z-[-1] pointer-events-none" aria-hidden="true">
      <div
        class="absolute top-[-10%] left-[-10%] w-[50%] h-[50%] rounded-full bg-blue-500/6 blur-[120px] will-change-transform"
      >
      </div>
      <div
        class="absolute bottom-[-10%] right-[-10%] w-[50%] h-[50%] rounded-full bg-emerald-500/8 blur-[120px] will-change-transform"
      >
      </div>
      <div
        class="absolute top-[20%] right-[20%] w-[30%] h-[30%] rounded-full bg-blue-500/10 blur-[100px] will-change-transform"
      >
      </div>
    </div>

    <Navigation />
    <main id="main-content" class="flex-grow">
      <slot />
    </main>
    <Footer />
  </body>
</html>

<style is:global>
  html {
    font-family: 'Varela Round', system-ui, sans-serif;
    scroll-behavior: smooth;
    scroll-padding-top: 5rem; /* Offset for fixed navbar */
    overflow-y: scroll; /* Prevent layout shift when content doesn't overflow */
  }

  /* Custom Scrollbar (matches landing) */
  ::-webkit-scrollbar {
    width: 10px;
  }
  ::-webkit-scrollbar-track {
    background: #0b1426; /* brand-dark */
  }
  ::-webkit-scrollbar-thumb {
    background: #1e293b; /* slate-800 */
    border-radius: 5px;
    border: 2px solid #0b1426;
  }
  ::-webkit-scrollbar-thumb:hover {
    background: #334155; /* slate-700 */
  }

  /* Respect reduced motion preferences */
  @media (prefers-reduced-motion: reduce) {
    *,
    *::before,
    *::after {
      animation-duration: 0.01ms !important;
      animation-iteration-count: 1 !important;
      transition-duration: 0.01ms !important;
      scroll-behavior: auto !important;
    }
  }
</style>
