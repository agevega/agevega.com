---
/**
 * RequestTraceSection — the live trace of the visitor's OWN request through the
 * production chain (Tú → CloudFront+WAF → ALB → EC2 → Nginx → Release). Rendered first
 * on /about-this-web, above the architecture overview, and carries the page's
 * only <h1>.
 *
 * Aesthetic: a terminal / network-waterfall trace (mono, hop rail, per-node
 * class tags) — deliberately distinct from the lifecycle diagram on the same
 * page. Every value is LIVE (Performance API / response headers / meta.json),
 * inferred-and-labeled, or static-true. Never fabricated.
 *
 * The dynamic values are written by infra-panel.client.ts (mountTrace). The
 * static HTML ships only placeholders, so there are no real-looking values in
 * the source.
 *
 * Node honesty classes:
 *   LIVE      — read from the visitor's request (TTFB, https/TLS scheme, instance az/type)
 *   inferido  — not client-readable, honestly inferred (CloudFront edge, WAF, ALB)
 *   estático  — a static truth of the repo (Terraform, nginx unprivileged)
 */
---

<section id="request-trace" data-state="loading" class="trace py-20 relative overflow-hidden">
  <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="mb-10 text-center">
      <h1 class="text-3xl md:text-4xl font-bold mb-4">
        <span class="text-transparent bg-clip-text bg-gradient-to-r from-blue-500 to-emerald-400"
          >Cómo se sirve este Sitio Web</span
        >
      </h1>
    </div>

    <!-- Terminal-style trace card -->
    <div
      class="trace-card bg-slate-900/60 border border-white/10 rounded-2xl backdrop-blur-xl overflow-hidden"
    >
      <!-- Window chrome -->
      <div class="flex items-center gap-2 px-5 py-3 border-b border-white/5 bg-black/20">
        <div class="w-3 h-3 rounded-full bg-red-500/50"></div>
        <div class="w-3 h-3 rounded-full bg-yellow-500/50"></div>
        <div class="w-3 h-3 rounded-full bg-green-500/50"></div>
        <span class="ml-2 text-xs font-mono text-slate-500">traza · petición → servidor web</span>
        <span
          data-trace-badge
          class="trace-badge ml-auto text-[10px] font-mono font-bold tracking-wider rounded-full px-2 py-0.5 border"
          aria-label="Estado de la traza">···</span
        >
      </div>

      <!-- Hops -->
      <ol
        class="trace-hops font-mono text-sm m-0 list-none p-5 sm:p-7"
        aria-live="polite"
        aria-label="Saltos de la petición"
      >
        <!-- 1. Origen -->
        <li class="hop">
          <div class="hop-rail"><span class="hop-dot hop-dot--origin"></span></div>
          <div class="hop-body">
            <div class="hop-head">
              <span class="hop-name">Tú</span>
              <span class="tag tag--live">LIVE</span>
            </div>
            <div class="hop-data">
              <span class="k">ttfb</span>
              <span class="v" data-field="ttfb">···</span>
              <span class="sep">·</span>
              <span class="k">tls</span>
              <span class="v" data-field="tls">···</span>
            </div>
          </div>
        </li>

        <!-- 2. CloudFront -->
        <li class="hop">
          <div class="hop-rail"><span class="hop-dot"></span></div>
          <div class="hop-body">
            <div class="hop-head">
              <span class="hop-name">CloudFront</span>
              <span class="hop-role">edge · cdn</span>
              <span class="tag tag--inf">inferido</span>
            </div>
            <div class="hop-data hop-data--muted">
              <span class="vi">AWS WAF · firewall</span>
            </div>
          </div>
        </li>

        <!-- 3. ALB -->
        <li class="hop">
          <div class="hop-rail"><span class="hop-dot"></span></div>
          <div class="hop-body">
            <div class="hop-head">
              <span class="hop-name">ALB</span>
              <span class="hop-role">balanceador</span>
              <span class="tag tag--inf">inferido</span>
            </div>
            <div class="hop-data hop-data--muted">
              <span class="vi">multi-AZ · Auto Scaling Group</span>
            </div>
          </div>
        </li>

        <!-- 4. EC2 / ASG -->
        <li class="hop">
          <div class="hop-rail"><span class="hop-dot hop-dot--compute"></span></div>
          <div class="hop-body">
            <div class="hop-head">
              <span class="hop-name">EC2</span>
              <span class="hop-role">compute · asg</span>
              <span class="tag tag--live">LIVE</span>
            </div>
            <div class="hop-data">
              <span class="k">az</span>
              <span class="v" data-field="traceAz">···</span>
              <span class="sep">·</span>
              <span class="k">type</span>
              <span class="v" data-field="traceType">···</span>
            </div>
          </div>
        </li>

        <!-- 5. Nginx / Docker -->
        <li class="hop">
          <div class="hop-rail"><span class="hop-dot"></span></div>
          <div class="hop-body">
            <div class="hop-head">
              <span class="hop-name">Nginx · Docker</span>
              <span class="hop-role">runtime</span>
              <span class="tag tag--static">estático</span>
            </div>
            <div class="hop-data hop-data--muted">
              <span class="vi">nginx unprivileged · contenedor no-root</span>
            </div>
          </div>
        </li>

        <!-- 6. Release -->
        <li class="hop hop--last">
          <div class="hop-rail"><span class="hop-dot"></span></div>
          <div class="hop-body">
            <div class="hop-head">
              <span class="hop-name">Release</span>
              <span class="hop-role">versión desplegada</span>
              <span class="tag tag--static">estático</span>
            </div>
            <div class="hop-data">
              <span class="k">version</span>
              <span class="v" data-field="traceRelease">···</span>
            </div>
          </div>
        </li>
      </ol>

      <!-- Footer: audit invitation / env note -->
      <div class="px-5 sm:px-7 py-4 border-t border-white/5 bg-black/10">
        <p data-trace-env class="text-xs text-slate-500 leading-relaxed min-h-[2.5rem] m-0">
          Trazando tu petición…
        </p>
      </div>
    </div>
  </div>
</section>

<style>
  /* State-dependent badge: live emerald, local neutral
     slate-blue (never red/broken), loading slate. Same layout in all states so
     filling values causes no layout shift (CLS ≈ 0). */
  .trace-badge {
    color: #64748b;
    border-color: rgba(100, 116, 139, 0.4);
    background: rgba(100, 116, 139, 0.08);
  }
  .trace[data-state='live'] .trace-badge {
    color: #34d399;
    border-color: rgba(52, 211, 153, 0.4);
    background: rgba(52, 211, 153, 0.1);
  }
  .trace[data-state='local'] .trace-badge {
    color: #7dd3fc;
    border-color: rgba(125, 211, 252, 0.35);
    background: rgba(125, 211, 252, 0.08);
  }

  /* Hop rail — the connecting line + dot that gives the waterfall/trace feel. */
  .hop {
    display: grid;
    grid-template-columns: 1.5rem 1fr;
    gap: 0.75rem;
    min-height: 4rem; /* reserved — no CLS when values arrive */
  }
  .hop-rail {
    position: relative;
    display: flex;
    justify-content: center;
  }
  .hop-rail::before {
    content: '';
    position: absolute;
    top: 0.9rem;
    bottom: -0.4rem;
    width: 1px;
    background: linear-gradient(to bottom, rgba(52, 211, 153, 0.35), rgba(59, 130, 246, 0.2));
  }
  .hop--last .hop-rail::before {
    display: none;
  }
  .hop-dot {
    position: relative;
    z-index: 1;
    margin-top: 0.55rem;
    width: 0.6rem;
    height: 0.6rem;
    border-radius: 9999px;
    background: #334155;
    border: 1px solid #475569;
  }
  .hop-dot--origin {
    background: #3b82f6;
    border-color: #60a5fa;
  }
  .hop-dot--compute {
    background: #10b981;
    border-color: #34d399;
  }
  .hop-body {
    padding-bottom: 1.1rem;
  }
  .hop-head {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-bottom: 0.35rem;
  }
  .hop-name {
    color: #e2e8f0;
    font-weight: 700;
  }
  .hop-role {
    font-size: 0.65rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: #64748b;
  }
  .hop-data {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 0.4rem;
    line-height: 1.6;
  }
  .hop-data--muted {
    margin-top: 0.15rem;
  }
  .k {
    color: #64748b;
  }
  .v {
    color: #34d399;
  }
  .vi {
    color: #94a3b8;
  }
  .sep {
    color: #334155;
  }
  .tag {
    font-size: 0.6rem;
    font-weight: 700;
    letter-spacing: 0.06em;
    border-radius: 9999px;
    padding: 0.05rem 0.4rem;
    border: 1px solid;
  }
  .tag--live {
    color: #34d399;
    border-color: rgba(52, 211, 153, 0.4);
    background: rgba(52, 211, 153, 0.08);
  }
  .tag--inf {
    color: #7dd3fc;
    border-color: rgba(125, 211, 252, 0.3);
    background: rgba(125, 211, 252, 0.06);
  }
  .tag--static {
    color: #94a3b8;
    border-color: rgba(148, 163, 184, 0.3);
    background: rgba(148, 163, 184, 0.06);
  }
  /* In the local fallback, the LIVE tags would lie — dim them to neutral. */
  .trace[data-state='local'] .tag--live {
    color: #7dd3fc;
    border-color: rgba(125, 211, 252, 0.3);
    background: rgba(125, 211, 252, 0.06);
  }
  .trace[data-state='local'] .v {
    color: #7dd3fc;
  }
</style>
