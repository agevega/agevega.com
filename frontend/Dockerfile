# Build stage
FROM node:lts-alpine as build

WORKDIR /app

# Arguments
ARG PUBLIC_APP_VERSION
ARG PUBLIC_API_URL
ENV PUBLIC_APP_VERSION=$PUBLIC_APP_VERSION
ENV PUBLIC_API_URL=$PUBLIC_API_URL

COPY package*.json ./
RUN npm install

COPY . .
RUN npm run build

# Runtime stage
# We use nginx to serve the static files generated by Astro
FROM nginx:alpine

# Install curl for IMDS fetching and openssl for self-signed certs
RUN apk add --no-cache curl openssl

# Generate self-signed certificate
RUN openssl req -x509 -nodes -days 365 -newkey rsa:2048 \
    -keyout /etc/nginx/server.key \
    -out /etc/nginx/server.crt \
    -subj "/C=ES/ST=Madrid/L=Madrid/O=Internal/OU=IT/CN=localhost"

# Copy static config and entrypoint
COPY ./nginx.conf /etc/nginx/conf.d/default.conf
COPY ./docker-entrypoint.sh /docker-entrypoint.sh
RUN chmod +x /docker-entrypoint.sh

# Copy built application
COPY --from=build /app/dist /usr/share/nginx/html

EXPOSE 443

ENTRYPOINT ["/docker-entrypoint.sh"]
CMD ["nginx", "-g", "daemon off;"]
