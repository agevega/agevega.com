---
import type { Lang } from "../i18n/translations";
import { useTranslations } from "../i18n/utils";

interface Props {
  lang?: Lang;
}

const { lang = 'es' } = Astro.props;
const t = useTranslations(lang);

const currentPath = Astro.url.pathname;
const esPath = currentPath.startsWith('/en/') ? currentPath.slice(3) || '/' : currentPath;
const enPath = currentPath.startsWith('/en/') ? currentPath : `/en${currentPath}`;
const toggleHref = lang === 'es' ? enPath : esPath;
const toggleLabel = t.nav.toggleLabel;
---

<nav class="fixed top-0 w-full z-50 transition-all duration-300" id="navbar" aria-label="Navegación principal">
  <div
    class="absolute inset-0 bg-brand-dark/80 backdrop-blur-md border-b border-white/10 shadow-lg"
  >
  </div>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative">
    <div class="flex items-center justify-between h-16">
      <!-- Logo -->
      <a href="/" class="flex-shrink-0" aria-label="Inicio - Alejandro Vega">
        <img
          src="/images/logos/original.png"
          alt="AV Logo"
          class="h-8 w-auto"
          width="32"
          height="32"
        />
      </a>

      <!-- Desktop Menu -->
      <div class="hidden md:block">
        <div class="ml-10 flex items-baseline space-x-4">
          <a
            href={lang === 'es' ? '/' : '/en/'}
            class="nav-link px-3 py-2 rounded-md text-sm font-medium text-slate-300 hover:text-white hover:bg-white/5 transition-all focus:outline-none focus-visible:ring-2 focus-visible:ring-emerald-500"
            >{t.nav.home}</a
          >
          <a
            href={lang === 'es' ? '/about-this-web' : '/en/about-this-web'}
            class="nav-link px-3 py-2 rounded-md text-sm font-medium text-slate-300 hover:text-white hover:bg-white/5 transition-all focus:outline-none focus-visible:ring-2 focus-visible:ring-emerald-500"
            >{t.nav.aboutThisWeb}</a
          >
          <a
            href={lang === 'es' ? '/about' : '/en/about'}
            class="nav-link px-3 py-2 rounded-md text-sm font-medium text-slate-300 hover:text-white hover:bg-white/5 transition-all focus:outline-none focus-visible:ring-2 focus-visible:ring-emerald-500"
            >{t.nav.about}</a
          >
          <a
            href={lang === 'es' ? '/laboratory' : '/en/laboratory'}
            class="nav-link px-3 py-2 rounded-md text-sm font-medium text-slate-300 hover:text-white hover:bg-white/5 transition-all focus:outline-none focus-visible:ring-2 focus-visible:ring-emerald-500"
            >{t.nav.laboratory}</a
          >
          <a
            href={lang === 'es' ? '/contact' : '/en/contact'}
            class="nav-link px-3 py-2 rounded-md text-sm font-medium text-white bg-emerald-600 hover:bg-emerald-500 shadow-lg shadow-emerald-500/20 transition-all focus:outline-none focus-visible:ring-2 focus-visible:ring-emerald-500 focus-visible:ring-offset-2 focus-visible:ring-offset-brand-dark"
            >{t.nav.contact}</a
          >
          <a
            href={toggleHref}
            class="px-3 py-2 rounded-md text-sm font-medium text-slate-300 hover:text-white hover:bg-white/5 border border-slate-700 transition-all focus:outline-none focus-visible:ring-2 focus-visible:ring-emerald-500"
            aria-label={lang === 'es' ? 'Switch to English' : 'Cambiar a Español'}
            >{toggleLabel}</a
          >
        </div>
      </div>

      <!-- Mobile Menu Button -->
      <div class="-mr-2 flex md:hidden">
        <button
          type="button"
          id="mobile-menu-btn"
          class="inline-flex items-center justify-center p-2 rounded-md text-slate-400 hover:text-white hover:bg-white/10 focus:outline-none focus:ring-2 focus:ring-inset focus:ring-emerald-500"
          aria-controls="mobile-menu"
          aria-expanded="false"
        >
          <span class="sr-only">{t.nav.openMenu}</span>
          <!-- Icon: Menu -->
          <svg
            class="block h-6 w-6"
            xmlns="http://www.w3.org/2000/svg"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
            aria-hidden="true"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M4 6h16M4 12h16M4 18h16"></path>
          </svg>
          <!-- Icon: X (hidden) -->
          <svg
            class="hidden h-6 w-6"
            xmlns="http://www.w3.org/2000/svg"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
            aria-hidden="true"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M6 18L18 6M6 6l12 12"></path>
          </svg>
        </button>
      </div>
    </div>
  </div>

  <!-- Mobile Menu -->
  <div
    class="md:hidden hidden bg-brand-dark/95 backdrop-blur-xl border-b border-white/10"
    id="mobile-menu"
  >
    <div class="px-2 pt-2 pb-3 space-y-1 sm:px-3">
      <a
        href={lang === 'es' ? '/' : '/en/'}
        class="mobile-nav-link block px-3 py-2 rounded-md text-base font-medium text-slate-300 hover:text-white hover:bg-white/5 focus:outline-none focus-visible:ring-2 focus-visible:ring-emerald-500"
        >{t.nav.home}</a
      >
      <a
        href={lang === 'es' ? '/about-this-web' : '/en/about-this-web'}
        class="mobile-nav-link block px-3 py-2 rounded-md text-base font-medium text-slate-300 hover:text-white hover:bg-white/5 focus:outline-none focus-visible:ring-2 focus-visible:ring-emerald-500"
        >{t.nav.aboutThisWeb}</a
      >
      <a
        href={lang === 'es' ? '/about' : '/en/about'}
        class="mobile-nav-link block px-3 py-2 rounded-md text-base font-medium text-slate-300 hover:text-white hover:bg-white/5 focus:outline-none focus-visible:ring-2 focus-visible:ring-emerald-500"
        >{t.nav.about}</a
      >
      <a
        href={lang === 'es' ? '/laboratory' : '/en/laboratory'}
        class="mobile-nav-link block px-3 py-2 rounded-md text-base font-medium text-slate-300 hover:text-white hover:bg-white/5 focus:outline-none focus-visible:ring-2 focus-visible:ring-emerald-500"
        >{t.nav.laboratory}</a
      >
      <a
        href={lang === 'es' ? '/contact' : '/en/contact'}
        class="mobile-nav-link block px-3 py-2 rounded-md text-base font-medium text-white bg-emerald-600 hover:bg-emerald-500 focus:outline-none focus-visible:ring-2 focus-visible:ring-emerald-500"
        >{t.nav.contact}</a
      >
      <a
        href={toggleHref}
        class="mobile-nav-link block px-3 py-2 rounded-md text-base font-medium text-slate-300 hover:text-white hover:bg-white/5 border border-slate-700 focus:outline-none focus-visible:ring-2 focus-visible:ring-emerald-500"
        aria-label={lang === 'es' ? 'Switch to English' : 'Cambiar a Español'}
        >{toggleLabel}</a
      >
    </div>
  </div>
</nav>

<script>
  const navbar = document.getElementById("navbar");
  const mobileMenuBtn = document.getElementById("mobile-menu-btn");
  const mobileMenu = document.getElementById("mobile-menu");
  const menuIcons = mobileMenuBtn?.querySelectorAll("svg");
  const mobileLinks = document.querySelectorAll(".mobile-nav-link");

  // Toggle Mobile Menu
  mobileMenuBtn?.addEventListener("click", () => {
    const isExpanded = mobileMenuBtn.getAttribute("aria-expanded") === "true";
    mobileMenuBtn.setAttribute("aria-expanded", `${!isExpanded}`);
    mobileMenu?.classList.toggle("hidden");

    // Toggle Icons
    menuIcons?.forEach((icon) => icon.classList.toggle("hidden"));
    menuIcons?.forEach((icon) => icon.classList.toggle("block"));
  });

  // Close mobile menu on link click
  mobileLinks.forEach((link) => {
    link.addEventListener("click", () => {
      mobileMenu?.classList.add("hidden");
      mobileMenuBtn?.setAttribute("aria-expanded", "false");
      // Reset icons
      menuIcons?.[0].classList.remove("hidden");
      menuIcons?.[0].classList.add("block");
      menuIcons?.[1].classList.add("hidden");
      menuIcons?.[1].classList.remove("block");
    });
  });

  // Highlight active link based on current page
  const navLinks = document.querySelectorAll(".nav-link");
  const mobileNavLinks = document.querySelectorAll(".mobile-nav-link");

  function setActiveLink(linkHref: string | null) {
    if (!linkHref) return;

    const normalize = (path: string) =>
      path === "/" || path === "" ? "/" : path.replace(/\/$/, "");
    const current = normalize(linkHref);

    const updateLinks = (links: NodeListOf<Element>) => {
      links.forEach((link) => {
        const href = link.getAttribute("href");
        if (href && normalize(href) === current) {
          if (!link.classList.contains("bg-emerald-600")) {
            link.classList.remove("text-slate-300");
            link.classList.add("text-white", "bg-white/10", "underline", "decoration-emerald-500", "underline-offset-4");
          }
        } else {
          if (!link.classList.contains("bg-emerald-600")) {
            link.classList.remove("text-white", "bg-white/10", "underline", "decoration-emerald-500", "underline-offset-4");
            link.classList.add("text-slate-300");
          }
        }
      });
    };

    updateLinks(navLinks);
    updateLinks(mobileNavLinks);
  }

  // Check if we are on a specific page
  const currentPath = window.location.pathname;
  setActiveLink(currentPath);

  // Navbar background on scroll
  window.addEventListener("scroll", () => {
    if (window.scrollY > 20) {
      navbar?.classList.add("py-2");
    } else {
      navbar?.classList.remove("py-2");
    }
  });

  // Focus trap for mobile menu
  function handleMobileMenuKeydown(e: KeyboardEvent) {
    if (e.key === "Escape") {
      mobileMenu?.classList.add("hidden");
      mobileMenuBtn?.setAttribute("aria-expanded", "false");
      menuIcons?.[0].classList.remove("hidden");
      menuIcons?.[0].classList.add("block");
      menuIcons?.[1].classList.add("hidden");
      menuIcons?.[1].classList.remove("block");
      mobileMenuBtn?.focus();
      return;
    }

    if (e.key !== "Tab") return;

    const focusableEls = mobileMenu?.querySelectorAll(
      'a[href], button, [tabindex]:not([tabindex="-1"])'
    );
    if (!focusableEls || focusableEls.length === 0) return;

    const firstEl = focusableEls[0] as HTMLElement;
    const lastEl = focusableEls[focusableEls.length - 1] as HTMLElement;

    if (e.shiftKey && document.activeElement === firstEl) {
      e.preventDefault();
      lastEl.focus();
    } else if (!e.shiftKey && document.activeElement === lastEl) {
      e.preventDefault();
      firstEl.focus();
    }
  }

  // Attach/detach focus trap when menu toggles
  const observer = new MutationObserver(() => {
    const isOpen = !mobileMenu?.classList.contains("hidden");
    if (isOpen) {
      document.addEventListener("keydown", handleMobileMenuKeydown);
    } else {
      document.removeEventListener("keydown", handleMobileMenuKeydown);
    }
  });

  if (mobileMenu) {
    observer.observe(mobileMenu, { attributes: true, attributeFilter: ["class"] });
  }
</script>
