---
import type { Lang } from "../i18n/translations";
import { useTranslations } from "../i18n/utils";

interface Props {
  lang?: Lang;
}

interface SkillGroup {
  category: string;
  items: string[];
}

const { lang = 'es' } = Astro.props;
const t = useTranslations(lang);

const skills: SkillGroup[] = [
  {
    category: "Cloud & Infra",
    items: ["AWS", "Terraform", "Ansible"],
  },
  {
    category: "Containers & Orchestration",
    items: ["Docker", "Kubernetes", "Helm", "ArgoCD"],
  },
  {
    category: "CI/CD & DevOps",
    items: ["Git", "GitHub Actions", "Jenkins"],
  },
  {
    category: "Observability",
    items: ["CloudWatch", "Grafana", "Prometheus", "ELK Stack"],
  },
  {
    category: "Languages & Tools",
    items: ["Linux CLI", "Python", "Nginx"],
  },
];
---

<section id="skills" class="py-20">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div>
      <h2 class="text-3xl md:text-4xl font-bold text-white mb-6">{t.techStack.title}</h2>
      <p class="text-slate-400 mb-12 max-w-3xl text-lg">
        {t.techStack.subtitle}
      </p>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        {
          skills.map((group) => (
            <div class="bg-slate-900 p-6 rounded-xl border border-slate-800">
              <h3 class="text-emerald-400 font-semibold mb-4">
                {group.category}
              </h3>
              <div class="flex flex-wrap gap-2">
                {group.items.map((item) => (
                  <span class="px-3 py-1 bg-slate-800 text-slate-300 text-sm rounded-md border border-slate-700">
                    {item}
                  </span>
                ))}
              </div>
            </div>
          ))
        }
      </div>
    </div>
  </div>
</section>
