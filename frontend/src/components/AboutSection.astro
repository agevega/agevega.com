---
import type { Lang } from "../i18n/translations";
import { useTranslations } from "../i18n/utils";

interface Props {
  lang?: Lang;
}

const { lang = 'es' } = Astro.props;
const t = useTranslations(lang);
---

<section id="about" class="py-20">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div>
      <h2 class="text-3xl md:text-4xl font-bold text-white mb-12">{t.about.title}</h2>

      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 text-slate-400">
        <!-- Columna Izquierda: Intro & Foto -->
        <div class="space-y-8">
          <div class="flex flex-col sm:flex-row items-center gap-6">
            <!-- Placeholder para Foto -->
            <div
              class="w-32 h-32 rounded-full border-2 border-emerald-500/30 flex-shrink-0 overflow-hidden"
            >
              <img
                src="/images/content/photo-me.jpg"
                alt="Alejandro Vega"
                class="w-full h-full object-cover"
                width="128"
                height="128"
                loading="lazy"
              />
            </div>
            <div>
              <h3 class="text-xl font-semibold text-white mb-2">
                Alejandro Vega Vaquero
              </h3>
              <p class="leading-relaxed text-emerald-300 font-medium">
                Senior DevSecOps & Cloud Architect
              </p>
              <p class="leading-relaxed mt-1">
                {t.about.subtitle}
              </p>
            </div>
          </div>

          <div class="prose prose-invert mt-4">
            <p>
              {t.about.description1}
            </p>
            <p>
              {t.about.description2}
            </p>
          </div>

          <div class="pt-4">
            <a
              href="/assets/docs/cv-alejandro-vega.pdf"
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center px-6 py-3 border border-transparent text-base font-medium rounded-md shadow-sm text-white bg-emerald-600 hover:bg-emerald-500 transition-colors"
            >
              {lang === 'es' ? 'Ver CV Completo' : 'View Full CV'}
              <svg
                xmlns="http://www.w3.org/2000/svg"
                class="h-5 w-5 ml-2"
                viewBox="0 0 20 20"
                fill="currentColor"
                aria-hidden="true"
              >
                <path
                  fill-rule="evenodd"
                  d="M3 17a1 1 0 011-1h12a1 1 0 110 2H4a1 1 0 01-1-1zm3.293-7.707a1 1 0 011.414 0L9 10.586V3a1 1 0 112 0v7.586l1.293-1.293a1 1 0 111.414 1.414l-3 3a1 1 0 01-1.414 0l-3-3a1 1 0 010-1.414z"
                  clip-rule="evenodd"></path>
              </svg>
            </a>
          </div>

          <div class="pt-6 flex gap-4">
            <a
              href="https://www.credly.com/badges/22c3c65f-db95-4405-aa33-047cf3456f3a"
              target="_blank"
              rel="noopener noreferrer"
              class="block w-16 h-16 transition-transform hover:scale-110"
              title="AWS Certified Cloud Practitioner"
            >
              <img
                src="/images/badges/aws-cloud-practitioner.png"
                alt="AWS Certified Cloud Practitioner Badge"
                class="w-full h-full object-contain"
                width="64"
                height="64"
                loading="lazy"
              />
            </a>
            <a
              href="https://www.credly.com/badges/94baed2a-e31f-4084-8a26-233ad8f9ae09"
              target="_blank"
              rel="noopener noreferrer"
              class="block w-16 h-16 transition-transform hover:scale-110"
              title="AWS Cloud Quest: Cloud Practitioner"
            >
              <img
                src="/images/badges/aws-cloud-quest-practitioner.png"
                alt="AWS Cloud Quest: Cloud Practitioner Badge"
                class="w-full h-full object-contain"
                width="64"
                height="64"
                loading="lazy"
              />
            </a>
          </div>
        </div>

        <!-- Columna Derecha: Educación y Certificaciones -->
        <div class="space-y-8">
          <div>
            <h3
              class="text-xl font-bold text-white mb-4 border-b border-white/10 pb-2"
            >
              {t.about.educationTitle}
            </h3>
            <ul class="space-y-4">
              <li class="bg-white/5 p-4 rounded-lg">
                <h4 class="text-white font-medium">
                  {lang === 'es' ? 'Ingeniería Informática - Ingeniería de Computadores' : 'Computer Science Engineering'}
                </h4>
                <p class="text-sm text-emerald-400">Universidad de Sevilla</p>
              </li>
              <li class="bg-white/5 p-4 rounded-lg">
                <h4 class="text-white font-medium">
                  Big Data & Internet of Things (Erasmus+)
                </h4>
                <p class="text-sm text-emerald-400">Hogeschool van Amsterdam</p>
              </li>
              <li class="bg-white/5 p-4 rounded-lg">
                <h4 class="text-white font-medium">
                  {lang === 'es' ? 'Experto Universitario en DevOps & Cloud Computing' : 'University Expert in DevOps & Cloud Computing'}
                </h4>
                <p class="text-sm text-emerald-400">
                  Universidad Internacional de La Rioja
                </p>
              </li>
            </ul>
          </div>

          <div>
            <h3
              class="text-xl font-bold text-white mb-4 border-b border-white/10 pb-2"
            >
              {t.about.certTitle}
            </h3>
            <ul class="grid grid-cols-1 sm:grid-cols-2 gap-3">
              <li
                class="border border-slate-700 rounded p-3 text-sm hover:border-emerald-500/50 transition-colors"
              >
                <span class="block text-emerald-300 font-semibold mb-1"
                  >AWS Certified Cloud Practitioner (2023)</span
                >
                {lang === 'es' ? 'Conceptos y mejores prácticas de servicios en AWS.' : 'AWS service concepts and best practices.'}
              </li>
              <li
                class="border border-slate-700 rounded p-3 text-sm hover:border-emerald-500/50 transition-colors"
              >
                <span class="block text-emerald-300 font-semibold mb-1"
                  >Bitnami Bootcamp (2020)</span
                >
                {lang === 'es' ? 'Mejores prácticas con Docker, Kubernetes y Helm' : 'Best practices with Docker, Kubernetes and Helm'}
              </li>
            </ul>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
