---
import type { Lang } from "../i18n/translations";
import { useTranslations } from "../i18n/utils";

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  lang?: Lang;
}

import Navigation from "../components/Navigation.astro";
import Footer from "../components/Footer.astro";
import "@fontsource/inter/300.css";
import "@fontsource/inter/400.css";
import "@fontsource/inter/500.css";
import "@fontsource/inter/600.css";
import "@fontsource/inter/700.css";

const { title, description, ogImage, lang = 'es' } = Astro.props;
const t = useTranslations(lang);
const DEFAULT_DESCRIPTION = t.layout.defaultDescription;
const resolvedDescription = description ?? DEFAULT_DESCRIPTION;
const baseOrigin = Astro.site ? Astro.site.origin : Astro.url.origin;
const ogImageUrl = ogImage ? `${baseOrigin}${ogImage}` : `${baseOrigin}/og-image.jpg`;

const currentPath = Astro.url.pathname;
const esPath = currentPath.startsWith('/en/') ? currentPath.slice(3) || '/' : currentPath;
const enPath = currentPath.startsWith('/en/') ? currentPath : `/en${currentPath}`;

const opengraph = {
  image: ogImageUrl,
  type: "website",
};
---

<!doctype html>
<html lang={lang} class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={resolvedDescription} />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <meta name="generator" content={Astro.generator} />
    <link rel="canonical" href={`${baseOrigin}${Astro.url.pathname}`} />
    <link rel="alternate" hreflang="es" href={`${baseOrigin}${esPath}`} />
    <link rel="alternate" hreflang="en" href={`${baseOrigin}${enPath}`} />
    <link rel="alternate" hreflang="x-default" href={`${baseOrigin}${esPath}`} />
    <title>{title}</title>

    <!-- Open Graph / Facebook -->
    <meta property="og:type" content={opengraph.type} />
    <meta property="og:url" content={Astro.url} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={resolvedDescription} />
    <meta property="og:image" content={opengraph.image} />

    <!-- Twitter -->
    <meta property="twitter:card" content="summary_large_image" />
    <meta property="twitter:url" content={Astro.url} />
    <meta property="twitter:title" content={title} />
    <meta property="twitter:description" content={resolvedDescription} />
    <meta property="twitter:image" content={opengraph.image} />
    <slot name="head" />
  </head>
  <body
    class="bg-brand-dark text-slate-100 font-sans antialiased selection:bg-emerald-500/30 overflow-x-hidden relative flex flex-col min-h-screen"
  >
    <!-- Skip to content -->
    <a
      href="#main-content"
      class="sr-only focus:not-sr-only focus:fixed focus:top-4 focus:left-4 focus:z-[100] focus:px-4 focus:py-2 focus:bg-emerald-600 focus:text-white focus:rounded-lg focus:outline-none"
    >
      {t.layout.skipToContent}
    </a>
    <!-- Background Gradient Effects -->
    <div class="fixed inset-0 z-[-1] pointer-events-none" aria-hidden="true">
      <div
        class="absolute top-[-10%] left-[-10%] w-[50%] h-[50%] rounded-full bg-blue-500/6 blur-[120px] will-change-transform"
      >
      </div>
      <div
        class="absolute bottom-[-10%] right-[-10%] w-[50%] h-[50%] rounded-full bg-emerald-500/8 blur-[120px] will-change-transform"
      >
      </div>
      <div
        class="absolute top-[20%] right-[20%] w-[30%] h-[30%] rounded-full bg-blue-500/10 blur-[100px] will-change-transform"
      >
      </div>
    </div>
    <Navigation lang={lang} />
    <main id="main-content" class="flex-grow">
      <slot />
    </main>
    <Footer lang={lang} />
  </body>
</html>

<style is:global>
  html {
    font-family: "Inter", system-ui, sans-serif;
    scroll-behavior: smooth;
    scroll-padding-top: 5rem; /* Offset for fixed navbar */
    overflow-y: scroll; /* Prevent layout shift when content doesn't overflow */
  }

  /* Custom Scrollbar */
  ::-webkit-scrollbar {
    width: 10px;
  }
  ::-webkit-scrollbar-track {
    background: #0b1426; /* brand-dark */
  }
  ::-webkit-scrollbar-thumb {
    background: #1e293b; /* slate-800 */
    border-radius: 5px;
    border: 2px solid #0b1426;
  }
  ::-webkit-scrollbar-thumb:hover {
    background: #334155; /* slate-700 */
  }

  /* Defer rendering of below-fold sections */
  #about, #experience, #skills, #projects, #contact, #lab {
    content-visibility: auto;
    contain-intrinsic-size: auto 500px;
  }

  /* Respect reduced motion preferences */
  @media (prefers-reduced-motion: reduce) {
    *,
    *::before,
    *::after {
      animation-duration: 0.01ms !important;
      animation-iteration-count: 1 !important;
      transition-duration: 0.01ms !important;
      scroll-behavior: auto !important;
    }
  }
</style>
