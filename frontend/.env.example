# ============================================
# Environment Variables for Astro Frontend
# ============================================
# Copy this file to .env and fill in the values
#
# IMPORTANT: .env is git-ignored and docker-ignored.
# Never commit secrets to the repository.
# ============================================

# API Gateway endpoint for contact form
# PUBLIC_API_URL is automatically set in CI/CD pipeline from SSM.
# ONLY set this manually for local development (e.g. http://localhost:4321/api/contact)
PUBLIC_API_URL=

# App version (optional, defaults to 'dev')
PUBLIC_APP_VERSION=dev
