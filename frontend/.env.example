# ============================================
# Environment Variables for Astro Frontend
# ============================================
# Copy this file to .env and fill in the values
#
# IMPORTANT: .env is git-ignored and docker-ignored.
# Never commit secrets to the repository.
# ============================================

# API Gateway endpoint for contact form
PUBLIC_API_URL=https://xxxxxxxxxx.execute-api.eu-south-2.amazonaws.com

# Application version - Automatically set by CI/CD from git tag
PUBLIC_APP_VERSION=dev
